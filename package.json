{
  "name": "@yalehwang/archguard",
  "version": "0.1.10",
  "type": "module",
  "description": "Automated architecture documentation generation tool with AI-powered Mermaid diagrams",
  "keywords": [
    "architecture",
    "documentation",
    "mermaid",
    "typescript",
    "ai",
    "claude"
  ],
  "files": [
    "dist/",
    "scripts/postinstall-tree-sitter.mjs",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "archguard": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias && bash scripts/fix-imports.sh && npx tsc scripts/migrate-to-mermaid.ts --outDir dist/scripts --module ESNext --target ES2022 --moduleResolution node --esModuleInterop --resolveJsonModule --skipLibCheck && chmod +x dist/cli/index.js",
    "dev": "tsc --watch",
    "postinstall": "node scripts/postinstall-tree-sitter.mjs",
    "prepack": "node scripts/stage-tree-sitter-prebuild.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "generate": "node dist/cli/index.js generate",
    "migrate": "node dist/scripts/migrate-to-mermaid.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "globby": "^16.1.1",
    "isomorphic-mermaid": "^0.1.1",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "p-map": "^7.0.4",
    "sharp": "^0.34.5",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.25.0",
    "ts-morph": "^27.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.0",
    "memfs": "^4.56.11",
    "prettier": "^3.1.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "bundleDependencies": [
    "tree-sitter"
  ],
  "overrides": {
    "tree-sitter": "^0.25.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yaleh/archguard.git"
  },
  "license": "MIT",
  "author": "yalehwang",
  "bugs": {
    "url": "https://github.com/yaleh/archguard/issues"
  },
  "homepage": "https://github.com/yaleh/archguard#readme"
}
